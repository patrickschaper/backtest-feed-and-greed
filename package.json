{
  "name": "backtest-feed-and-greed",
  "version": "1.0.0",
  "description": "CLI backtester for Fear & Greed stock strategy",
  "main": "dist/cli.js",
  "bin": {
    "btfeargreed": "dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "start": "node dist/cli.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "prepare": "husky",
    "prepack": "npm run build",
    "check": "npm run lint && npm run test && npm run build"
  },
  "keywords": [],
  "files": [
    "dist",
    "README.md",
    ".env.example"
  ],
  "author": "",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@mathieuc/tradingview": "^3.5.2",
    "asciichart": "^1.5.25",
    "cli-table3": "^0.6.5",
    "commander": "^15.0.0",
    "dotenv": "^17.4.2",
    "yahoo-finance2": "^3.15.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/asciichart": "^1.5.8",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs,json,md}": [
      "prettier --write"
    ],
    "*.{ts,tsx,js,mjs,cjs}": [
      "eslint --fix"
    ]
  }
}
