# Trading212 API Configuration
# Get your API Key and API Secret from: https://www.trading212.com/api-docs
# Format: API_KEY:API_SECRET
TRADING212_API_TOKEN=your-api-key:your-api-secret

# Optional: TradingView session cookies (for accessing more data without rate limits)
# Retrieve from browser DevTools → Application → Cookies on tradingview.com
# Without these, basic historical data still works for major exchanges (but may be throttled).
# TRADINGVIEW_SESSION=your-sessionid-cookie
# TRADINGVIEW_SIGNATURE=your-tradingviewui_sign-cookie
